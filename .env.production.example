# Required — CLIProxyAPI handles multi-model access (Claude, Gemini, Cursor, etc.)
CLIPROXY_API_KEY=your-api-key-1

# Optional — direct Gemini grounded search (bypasses CLIProxyAPI for grounded calls)
GEMINI_API_KEY=your-gemini-api-key

# Required — domain for Caddy auto-HTTPS
DOMAIN=recon.example.com

# Note: CLIPROXY_URL is set automatically in docker-compose.yml (http://cliproxy:8317)
# Note: ANTHROPIC_API_KEY is NOT needed — CLIProxyAPI handles Claude access via OAuth

# Optional — Sentry monitoring
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# SENTRY_ORG=
# SENTRY_PROJECT=

# Optional — Better Stack logs + OTLP traces
# TELEMETRY_SINKS=ndjson,betterstack
# BETTERSTACK_SOURCE_TOKEN=
# BETTERSTACK_LOG_ENDPOINT=https://in.logs.betterstack.com
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <token>
