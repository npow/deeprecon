# Required — at least one AI provider needed
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key

# Optional — multi-provider proxy for parallel research
# CLIPROXY_URL=http://localhost:8317
# CLIPROXY_API_KEY=your-proxy-api-key

# Optional — DeerFlow sidecar for deep-research offload (orthogonal to runtime scan fanout)
# DEERFLOW_URL=http://localhost:9000
# DEERFLOW_ENDPOINT=/research
# DEERFLOW_API_KEY=your-deerflow-api-key
# DEEP_RESEARCH_DEERFLOW_TIMEOUT_MS=600000

# Optional — disable scan API rate limiting (auto-disabled in non-production already)
# DISABLE_SCAN_RATE_LIMIT=1
# REDIS_URL=redis://localhost:6379
# SCAN_REDIS_PREFIX=deeprecon
# SCAN_QUEUE_POLL_MS=250

# Optional — speed up scan fan-out while iterating (fewer models + shorter timeouts)
# SCAN_DEV_FAST_MODE=1

# Optional — disable Gemini grounded calls in fan-out stages
# DISABLE_GEMINI_GROUNDED=1

# Optional — scan timeout tuning (ms)
# SCAN_TIMEOUT_CLIPROXY_MS=200000
# SCAN_TIMEOUT_GEMINI_MS=120000
# SCAN_TIMEOUT_FAST_MS=60000

# Optional — telemetry and OpenTelemetry export
# SCAN_TELEMETRY_ENABLED=1
# TELEMETRY_SINKS=ndjson
# TELEMETRY_NDJSON_PATH=./data/telemetry/events.ndjson
# BETTERSTACK_SOURCE_TOKEN=your-betterstack-source-token
# BETTERSTACK_LOG_ENDPOINT=https://in.logs.betterstack.com
# BETTERSTACK_LOG_TIMEOUT_MS=2000
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer your-token
# OTEL_CONSOLE_EXPORTER=0

# Optional — Sentry error + trace monitoring
# SENTRY_DSN=https://<key>@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=development
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project

# Future: Add for richer competitive data
# CRUNCHBASE_API_KEY=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# PRODUCTHUNT_ACCESS_TOKEN=

# Future: Add for persistence & auth
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional — Postgres (preferred standard names)
# DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=require
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=postgres
#
# Legacy compatibility (if already using these):
# PSQL_HOST=
# PSQL_PORT=
# PSQL_USER=
# PSQL_PASSWORD=
# PSQL_DATABASE=

# Future: Add for payments
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
